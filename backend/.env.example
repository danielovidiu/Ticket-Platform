# ---- Core (required) ----
MONGO_URL=mongodb://localhost:27017
DB_NAME=ticket_platform_local

# Deployment environment. When "production", the app fails to start unless
# SESSION_SECRET and an explicit CORS_ORIGINS allowlist are set.
APP_ENV=development

# Public origin of the FRONTEND. OAuth callbacks and all email links point here,
# and its scheme decides session-cookie scoping (https => SameSite=None; Secure).
PUBLIC_APP_URL=http://localhost:3000

# Signs email-verification / password-reset / newsletter tokens. REQUIRED in
# production. Generate with:  python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=

# Version string stamped onto consent-log entries; bump when your ToS/Privacy change.
POLICY_VERSION=2026-07-22

# Comma-separated CORS allowlist. MUST be explicit in production (no "*") because
# requests are credentialed. In dev, leave blank to default to PUBLIC_APP_URL.
CORS_ORIGINS=

# Promote this email to admin on every startup (bootstraps the first admin safely).
INITIAL_ADMIN_EMAIL=

# ---- Email (optional; falls back to db.outbox + logs when unset) ----
RESEND_API_KEY=
MAIL_FROM=Supersanity <tickets@supersanity.example>

# ---- Payments ----
# Leave STRIPE_API_KEY blank (or set LOCAL_FAKE_PAYMENTS=1) to run the local fake
# payment simulator — the full reserve->pay->ticket flow works with no Stripe account.
# A real "sk_..." key switches to live Stripe and then STRIPE_WEBHOOK_SECRET is REQUIRED.
#
# !! DEVELOPMENT ONLY. In the fake simulator both /api/payments/status/{id} and
# !! /api/webhook/stripe finalize orders with NO authentication and NO signature — anyone
# !! who can reach the instance can issue themselves real tickets and a real invoice for
# !! free. The fallback is SILENT: a missing or malformed key selects it even when
# !! APP_ENV=production. Verify PAYMENTS_MODE=="stripe" on every deployed environment.
# !! See SECURITY_AUDIT.md finding C1.
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
LOCAL_FAKE_PAYMENTS=1

# ---- Google OAuth (optional; button hidden until all three are set) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# ---- Apple Sign In (optional; needs a PUBLIC https callback — not testable on localhost) ----
# NOTE: TEAM_ID / KEY_ID / PRIVATE_KEY are currently inert. They gate APPLE_ENABLED but
# nothing reads them: the flow uses response_type="code id_token" and only verifies the
# id_token, so the client-secret JWT they exist to sign is never built. You must still
# set them to switch Apple on. See SECURITY_AUDIT.md → "Dead configuration".
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_REDIRECT_URI=
